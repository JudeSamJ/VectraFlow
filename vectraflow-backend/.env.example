# App
APP_NAME=VectraFlow RAG API
ENVIRONMENT=development
SECRET_KEY=synapse_super_secret_key_12345
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/synapse

# Redis
REDIS_URL=redis://redis:6379/0

# Milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# Object storage (MinIO)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=synapse-documents
MINIO_SECURE=false

# Auth
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Embedding providers (defaults; per-KB overrides stored encrypted in DB)
OPENAI_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=
HUGGINGFACE_TEI_ENDPOINT=

# LLM providers
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AWS_BEDROCK_REGION=

# Reranker
COHERE_RERANK_API_KEY=
JINA_RERANK_API_KEY=
LOCAL_RERANKER_ENDPOINT=

# Vision
VISION_CAPTIONING_PROVIDER=anthropic

# Governance & PII
PII_DETECTION_ENABLED=true
DEFAULT_PII_ACTION=redact_before_send
AUDIT_LOG_RETENTION_DAYS=2555

# Agentic retrieval limits
AGENTIC_MAX_STEPS=4
AGENTIC_MAX_COST_USD=0.50
AGENTIC_MAX_WALL_CLOCK_SECONDS=60

# Resilience
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW_SECONDS=60
INGESTION_PER_DOCUMENT_TIMEOUT_SECONDS=600
INGESTION_MAX_RETRY_ATTEMPTS=3
INGESTION_PER_KB_CONCURRENCY_LIMIT=10

# Versioning
DOCUMENT_VERSION_RETENTION_DAYS=90

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# Encryption
ENCRYPTION_KEY=XGzHwE7xQc3O6Jk_z-oB7zF1HkGtR3dK8xW2J5V9YqQ=
